---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  readingTime: number;
}

const { title, description, date, slug, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article>
  <a href={`${import.meta.env.BASE_URL}posts/${slug}`} class="group block py-7">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1">
        <h2 class="text-[1.1rem] font-semibold leading-snug text-gray-900 transition-colors group-hover:text-accent dark:text-white dark:group-hover:text-accent-light">
          {title}
        </h2>
        <p class="mt-2 line-clamp-2 text-[0.925rem] leading-relaxed text-gray-500 dark:text-gray-400">
          {description}
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          <span class="text-sm text-gray-400 dark:text-gray-500">
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </span>
          <span class="text-gray-300 dark:text-gray-700">&bull;</span>
          <span class="text-sm text-gray-400 dark:text-gray-500">{readingTime} min read</span>
          {tags && tags.length > 0 && (
            <>
              <span class="text-gray-300 dark:text-gray-700">&bull;</span>
              <div class="flex flex-wrap gap-1.5">
                {tags.map((tag) => (
                  <span class="text-sm text-gray-400 dark:text-gray-600">
                    #{tag}
                  </span>
                ))}
              </div>
            </>
          )}
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-gray-300 transition-all group-hover:translate-x-0.5 group-hover:text-accent dark:text-gray-700 dark:group-hover:text-accent-light">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </div>
  </a>
</article>
