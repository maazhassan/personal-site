---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getReadingTime, MONTH_NAMES } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  const years = new Set<number>();
  posts.forEach((post) => years.add(post.data.date.getFullYear()));

  return Array.from(years).map((year) => {
    const yearPosts = posts
      .filter((p) => p.data.date.getFullYear() === year)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    const grouped = new Map<number, typeof yearPosts>();
    for (const post of yearPosts) {
      const month = post.data.date.getMonth();
      if (!grouped.has(month)) grouped.set(month, []);
      grouped.get(month)!.push(post);
    }

    return {
      params: { year: String(year) },
      props: { year, posts: yearPosts, grouped },
    };
  });
}

const { year, posts, grouped } = Astro.props;
const months = Array.from(grouped.keys()).sort((a, b) => b - a);
---

<BaseLayout title={`${year} - Archive`}>
  <Breadcrumbs archive={[
    { label: 'Archive', href: `${import.meta.env.BASE_URL}archive/` },
    { label: String(year) },
  ]} />

  <div class="mb-8 mt-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
      {year}
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">
      {posts.length} post{posts.length !== 1 ? 's' : ''} from {year}
    </p>
  </div>

  <div class="space-y-10">
    {months.map((month) => {
      const monthPosts = grouped.get(month)!;
      const monthNum = String(month + 1).padStart(2, '0');
      return (
        <section>
          <h2 class="mb-1 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
            <a
              href={`${import.meta.env.BASE_URL}archive/${year}/${monthNum}/`}
              class="transition-colors hover:text-accent dark:hover:text-accent-light"
            >
              {MONTH_NAMES[month]}
            </a>
          </h2>
          <div class="divide-y divide-gray-100 dark:divide-gray-800/50">
            {monthPosts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.id}
                tags={post.data.tags}
                readingTime={getReadingTime(post.body ?? '')}
              />
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
