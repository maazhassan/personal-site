---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getReadingTime, MONTH_NAMES } from '../../utils/posts';

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
})).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = new Map<number, Map<number, typeof posts>>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  const month = post.data.date.getMonth();
  if (!grouped.has(year)) grouped.set(year, new Map());
  const yearMap = grouped.get(year)!;
  if (!yearMap.has(month)) yearMap.set(month, []);
  yearMap.get(month)!.push(post);
}

const years = Array.from(grouped.keys()).sort((a, b) => b - a);
---

<BaseLayout title="Archive - Blog">
  <Breadcrumbs archive={[{ label: 'Archive' }]} />

  <div class="mb-8 mt-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
      Archive
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">
      {posts.length} post{posts.length !== 1 ? 's' : ''} across all time
    </p>
  </div>

  <div class="space-y-12">
    {years.map((year) => {
      const yearMap = grouped.get(year)!;
      const months = Array.from(yearMap.keys()).sort((a, b) => b - a);
      return (
        <section>
          <h2 class="mb-6 text-xl font-bold text-gray-900 dark:text-white">
            <a
              href={`${import.meta.env.BASE_URL}archive/${year}/`}
              class="transition-colors hover:text-accent dark:hover:text-accent-light"
            >
              {year}
            </a>
          </h2>
          <div class="space-y-8 border-l-2 border-gray-200 pl-6 dark:border-gray-800">
            {months.map((month) => {
              const monthPosts = yearMap.get(month)!;
              const monthNum = String(month + 1).padStart(2, '0');
              return (
                <div>
                  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                    <a
                      href={`${import.meta.env.BASE_URL}archive/${year}/${monthNum}/`}
                      class="transition-colors hover:text-accent dark:hover:text-accent-light"
                    >
                      {MONTH_NAMES[month]}
                    </a>
                    <span class="ml-2 font-normal text-gray-400 dark:text-gray-600">
                      ({monthPosts.length})
                    </span>
                  </h3>
                  <ul class="space-y-2">
                    {monthPosts.map((post) => (
                      <li class="flex items-baseline gap-3">
                        <time
                          datetime={post.data.date.toISOString()}
                          class="shrink-0 text-sm tabular-nums text-gray-400 dark:text-gray-600"
                        >
                          {post.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'short' })}
                        </time>
                        <a
                          href={`${import.meta.env.BASE_URL}posts/${post.id}`}
                          class="text-[0.95rem] text-gray-700 transition-colors hover:text-accent dark:text-gray-300 dark:hover:text-accent-light"
                        >
                          {post.data.title}
                        </a>
                        <span class="text-sm text-gray-400 dark:text-gray-600">
                          {getReadingTime(post.body ?? '')} min
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
