---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readingTime: number;
}

const { title, description, date, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} - Blog`} description={description}>
  <article>
    <Breadcrumbs title={title} />

    <header class="mt-8 mb-10">
      <h1 class="text-[2.25rem] font-extrabold leading-[1.15] tracking-tight text-gray-900 sm:text-[2.75rem] dark:text-white">
        {title}
      </h1>

      <p class="mt-4 text-lg leading-relaxed text-gray-500 dark:text-gray-400">
        {description}
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-400 dark:text-gray-500">
        <time datetime={date.toISOString()}>
          {formattedDate}
        </time>
        <span class="text-gray-300 dark:text-gray-700">&bull;</span>
        <span>{readingTime} min read</span>
      </div>

      {tags && tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`${import.meta.env.BASE_URL}tags/${tag}`}
              class="rounded-full border border-gray-200 px-3 py-1 text-xs font-medium text-gray-500 transition-colors hover:border-accent/30 hover:text-accent dark:border-gray-800 dark:text-gray-400 dark:hover:border-accent/40 dark:hover:text-accent-light"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <div class="mt-10 h-px bg-linear-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-p:leading-[1.8] prose-li:leading-[1.7]">
      <slot />
    </div>

    <footer class="mt-16 border-t border-gray-100 pt-8 dark:border-gray-800/50">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="group inline-flex items-center gap-2 text-sm font-medium text-gray-400 transition-colors hover:text-accent dark:text-gray-500 dark:hover:text-accent-light"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to all posts
      </a>
    </footer>
  </article>
</BaseLayout>
